# Normalize line endings
* text=auto eol=lf

# COBOL / JCL / copybooks — keep mainframe line endings stable
*.cob   text eol=lf
*.cbl   text eol=lf
*.cpy   text eol=lf
*.jcl   text eol=lf
*.proc  text eol=lf

# Markdown & docs
*.md    text eol=lf diff=markdown
*.json  text eol=lf
*.yml   text eol=lf
*.yaml  text eol=lf

# Java
*.java  text eol=lf diff=java

# Binary
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.pdf   binary

