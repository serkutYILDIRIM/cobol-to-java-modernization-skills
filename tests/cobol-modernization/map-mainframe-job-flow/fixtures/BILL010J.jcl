//BILL010J JOB (ACCT#1234),'NIGHTLY BILLING',CLASS=A,MSGCLASS=X,
//             REGION=0M,NOTIFY=&SYSUID,RESTART=STEP020
//*
//* NIGHTLY BILLING JOB — invokes the BILL010 program after IDCAMS
//* defines the work GDG generation, then archives outputs.
//*
//JOBLIB   DD  DSN=PROD.LOADLIB,DISP=SHR
//         DD  DSN=PROD.DB2.LOADLIB,DISP=SHR
//JCLLIB   ORDER=(PROD.PROCLIB,SHARED.PROCLIB)
//*
//         SET RUNDATE=20260519
//         SET INDSN=PROD.BILLING.INPUT
//*
//STEP010  EXEC PGM=IDCAMS
//SYSPRINT DD  SYSOUT=*
//SYSIN    DD  *
  DELETE PROD.BILLING.WORK.G0001V00 CLUSTER
  SET MAXCC = 0
  DEFINE CLUSTER (NAME(PROD.BILLING.WORK.G0001V00) -
                  INDEXED KEYS(11 0) RECORDSIZE(200 200) -
                  VOLUMES(SMS001) SHAREOPTIONS(2 3))
/*
//*
//STEP020  EXEC PGM=BILL010,PARM='RUNDATE=&RUNDATE'
//STEPLIB  DD  DSN=PROD.BILL010.LOADLIB,DISP=SHR
//CUSTMAST DD  DSN=&INDSN..CUSTMAST,DISP=SHR
//BILLOUT  DD  DSN=PROD.BILLING.OUTPUT(+1),
//             DISP=(NEW,CATLG,DELETE),
//             SPACE=(CYL,(50,10),RLSE),
//             DCB=(RECFM=FB,LRECL=200,BLKSIZE=0)
//WORKVSAM DD  DSN=PROD.BILLING.WORK.G0001V00,DISP=OLD
//ERRRPT   DD  SYSOUT=*
//SYSOUT   DD  SYSOUT=*
//SYSUDUMP DD  SYSOUT=*
//*
//STEP030  EXEC PROC=ARCHPROC,GEN=+1,SRCDSN=PROD.BILLING.OUTPUT
//*
// IF (STEP020.RC = 0) THEN
//STEP040  EXEC PGM=DB2LOAD,COND=(0,NE,STEP020)
//STEPLIB  DD  DSN=PROD.DB2.LOADLIB,DISP=SHR
//SYSREC   DD  DSN=PROD.BILLING.OUTPUT(0),DISP=SHR
//SYSPRINT DD  SYSOUT=*
//SYSIN    DD  *
  LOAD DATA REPLACE INTO TABLE BILLING.INVOICE
       (INVNO POSITION(1:11) CHAR,
        AMT   POSITION(12:20) DECIMAL EXTERNAL)
/*
// ELSE
//STEP041  EXEC PGM=IEFBR14
//ABORTLOG DD  SYSOUT=*
// ENDIF
//*
//STEP050  EXEC PGM=IEBGENER,COND=(4,LT,STEP020)
//SYSUT1   DD  DSN=PROD.BILLING.OUTPUT(0),DISP=SHR
//SYSUT2   DD  SYSOUT=A
//SYSIN    DD  DUMMY
//SYSPRINT DD  SYSOUT=*
//

